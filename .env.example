# JWT: optional for Docker. If empty, the container creates /app/data/.jwt_secret (persisted on volume).
# For local `pnpm dev`, set JWT_SECRET or the app may reject auth until you set one.
JWT_SECRET=

# SQLite (default): path relative to repo root for host dev; Docker Compose uses file:/app/data/dev.db.
DATABASE_URL="file:./data/dev.db"

# NEXT_PUBLIC_BASE_URL=https://your-domain.com
# APP_PORT=3000

# --- Optional integrations ---
# HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET_KEY=
# STEAM_API_KEY=
# REDIS_URL=redis://localhost:6379
# USE_NOSQL_AS_CACHE_REDIS=true
# REDIS_CACHE_TTL_SECONDS=3600

# --- Memos -> Inspiration sync (optional) ---
# Public Memos are synced into inspiration entries through /api/inspiration/memos-webhook.
# Set the same secret in Memos webhook signingSecret and in Waken.
# MEMOS_WEBHOOK_SECRET=
# MEMOS_BASE_URL=https://memos.apograss.cn
# WAKEN_MEMOS_WEBHOOK_URL=https://test.apograss.cn/api/inspiration/memos-webhook

# --- PostgreSQL (optional; not used by default docker-compose) ---
# Set DATABASE_URL or POSTGRES_URL to postgres://... and use schema postgres / build:postgres as documented in package.json.
